{
    "name": "@arcdev-llc/pi-lsp",
    "version": "1.1.0",
    "description": "Semantic code navigation, diagnostics, and refactoring for pi via Language Server Protocol (definition, references, hover, rename, code actions, workspace diagnostics) across Dart/Flutter, TypeScript, Vue, Svelte, Python, Go, Kotlin, Swift, and Rust",
    "scripts": {
        "build": "rslib build",
        "publish:github": "npm publish",
        "test": "npx tsx tests/lsp.test.ts",
        "test:tool": "npx tsx tests/index.test.ts",
        "test:integration": "npx tsx tests/lsp-integration.test.ts",
        "test:all": "npm test && npm run test:tool && npm run test:integration",
        "prepublishOnly": "npm run build",
        "postinstall": "npm run build"
    },
    "keywords": [
        "lsp",
        "language-server",
        "dart",
        "flutter",
        "typescript",
        "vue",
        "svelte",
        "python",
        "go",
        "kotlin",
        "swift",
        "rust",
        "pi-coding-agent",
        "extension",
        "pi-package",
        "go-to-definition",
        "find-references",
        "rename-symbol",
        "diagnostics",
        "code-actions",
        "semantic-navigation",
        "refactoring",
        "type-information"
    ],
    "author": "",
    "license": "MIT",
    "type": "module",
    "files": [
        "dist",
        "skills",
        "README.md"
    ],
    "main": "./dist/lsp.js",
    "types": "./dist/lsp.d.ts",
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "pi": {
        "extensions": [
            "./dist/lsp.js",
            "./dist/lsp-tool.js"
        ],
        "skills": [
            "./skills"
        ]
    },
    "dependencies": {
        "@sinclair/typebox": "^0.34.33",
        "vscode-languageserver-protocol": "^3.17.5"
    },
    "peerDependencies": {
        "bun": "*",
        "@mariozechner/pi-ai": "^0.50.0",
        "@mariozechner/pi-coding-agent": "^0.50.0",
        "@mariozechner/pi-tui": "^0.50.0"
    },
    "devDependencies": {
        "@mariozechner/pi-ai": "^0.50.0",
        "@mariozechner/pi-coding-agent": "^0.50.0",
        "@mariozechner/pi-tui": "^0.50.0",
        "@rslib/core": "^0.21.0",
        "@types/node": "^24.10.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
